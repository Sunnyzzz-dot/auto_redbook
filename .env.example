APP_ENV=local
APP_SECRET_KEY=change-me-to-a-32-byte-secret
DATABASE_URL=postgresql+asyncpg://redbook:redbook@localhost:5432/redbook_agent
SYNC_DATABASE_URL=postgresql://redbook:redbook@localhost:5432/redbook_agent
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=redbook-agent
S3_PUBLIC_BASE_URL=http://localhost:9000/redbook-agent
WORKER_ASSET_BASE_URL=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WORKER_TOKEN=change-me-worker-token
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
# Replace these with the text and image model endpoint IDs enabled in Volcengine Ark.
DOUBAO_TEXT_MODEL=doubao-seed-2-0-lite-260215
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
DOUBAO_IMAGE_SIZE=2K
# Set to false when you want missing/invalid model keys to fail instead of using demo mock output.
ALLOW_MOCK_MODELS=true
JWT_EXPIRES_MINUTES=10080
