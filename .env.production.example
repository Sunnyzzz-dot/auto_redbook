APP_ENV=production
APP_SECRET_KEY=change-me-to-a-long-random-secret

POSTGRES_USER=redbook
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=redbook_agent
DATABASE_URL=postgresql+asyncpg://redbook:change-me-postgres-password@postgres:5432/redbook_agent
SYNC_DATABASE_URL=postgresql://redbook:change-me-postgres-password@postgres:5432/redbook_agent

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-minio-password
S3_BUCKET=redbook-agent
S3_PUBLIC_BASE_URL=http://minio:9000/redbook-agent

LOCAL_UPLOAD_DIR=uploads
PUBLIC_UPLOAD_BASE_URL=https://YOUR_SERVER_PUBLIC_IP/uploads
WORKER_ASSET_BASE_URL=http://api:8000
CORS_ORIGINS=https://YOUR_SERVER_PUBLIC_IP

WORKER_TOKEN=change-me-worker-token
WORKER_ID=cloud-worker
MACHINE_NAME=volcengine-ecs
API_BASE_URL=http://api:8000
API_WS_URL=ws://api:8000
HEADLESS=true
PUBLISH_TIMEOUT_SECONDS=300
XHS_CREATOR_URL=https://creator.xiaohongshu.com/publish/publish

ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
DOUBAO_TEXT_MODEL=doubao-seed-2-0-lite-260215
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
